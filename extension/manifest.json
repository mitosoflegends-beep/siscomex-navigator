{
  "manifest_version": 3,
  "name": "Siscomex Auto - Consultar Duimp",
  "version": "1.0.0",
  "description": "Automatiza navegação no Portal Único Siscomex até Consultar Duimp após login com certificado.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["https://portalunico.siscomex.gov.br/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}